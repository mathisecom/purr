<section
  id="pureva-faq-{{ section.id }}"
  class="pureva-faq-section"
  style="
    --faq-bg: {{ section.settings.section_background }};
    --faq-text: {{ section.settings.text_color }};
    --faq-muted: {{ section.settings.muted_text_color }};
    --faq-border: {{ section.settings.border_color }};
    --faq-card-bg: {{ section.settings.card_background }};
    --faq-icon-bg: {{ section.settings.icon_background }};
    --faq-icon-color: {{ section.settings.icon_color }};
    --faq-button-bg: {{ section.settings.button_background }};
    --faq-button-text: {{ section.settings.button_text_color }};
    --faq-max-width: {{ section.settings.max_width }}px;
    --faq-padding-y: {{ section.settings.desktop_padding_y }}px;
    --faq-mobile-padding-y: {{ section.settings.mobile_padding_y }}px;
  "
>
  <div class="pureva-faq-container">
    <div class="pureva-faq-left">
      <div class="pureva-faq-left-header">
        {% if section.settings.heading != blank %}
          <h2 class="pureva-faq-heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.avatar_1 != blank or section.settings.avatar_2 != blank or section.settings.avatar_3 != blank %}
          <div class="pureva-faq-avatars">
            {% if section.settings.avatar_1 != blank %}
              <img src="{{ section.settings.avatar_1 | image_url: width: 80 }}" alt="{{ section.settings.avatar_alt_1 | escape }}" loading="lazy">
            {% endif %}
            {% if section.settings.avatar_2 != blank %}
              <img src="{{ section.settings.avatar_2 | image_url: width: 80 }}" alt="{{ section.settings.avatar_alt_2 | escape }}" loading="lazy">
            {% endif %}
            {% if section.settings.avatar_3 != blank %}
              <img src="{{ section.settings.avatar_3 | image_url: width: 80 }}" alt="{{ section.settings.avatar_alt_3 | escape }}" loading="lazy">
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if section.settings.description != blank %}
        <p class="pureva-faq-description">
          {{ section.settings.description }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="pureva-faq-button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <div class="pureva-faq-right">
      <div class="pureva-faq-items">
        {% for block in section.blocks %}
          {% if block.type == 'question' %}
            <div class="pureva-faq-item" {{ block.shopify_attributes }}>
              <button class="pureva-faq-question" type="button" aria-expanded="false">
                <span>{{ block.settings.question }}</span>
                <span class="pureva-faq-plus">+</span>
              </button>

              <div class="pureva-faq-answer">
                <div>
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="pureva-faq-benefits">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <div class="pureva-faq-benefit" {{ block.shopify_attributes }}>
              <span class="pureva-faq-benefit-icon">
                {{ section.settings.check_icon_svg }}
              </span>

              <div>
                {% if block.settings.title != blank %}
                  <strong>{{ block.settings.title }}</strong>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800;900&display=swap');

  #pureva-faq-{{ section.id }} {
    width: 100%;
    background: var(--faq-bg);
    color: var(--faq-text);
    font-family: 'Instrument Sans', Arial, Helvetica, sans-serif;
    padding: var(--faq-padding-y) {{ section.settings.desktop_padding_x }}px;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-container {
    width: 100%;
    max-width: var(--faq-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: {{ section.settings.left_column_width }}fr {{ section.settings.right_column_width }}fr;
    gap: {{ section.settings.desktop_gap }}px;
    align-items: center;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-left {
    width: 100%;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-left-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: {{ section.settings.heading_bottom_spacing }}px;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-heading {
    margin: 0;
    color: var(--faq-text);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: -0.6px;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-avatars {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-avatars img {
    width: {{ section.settings.avatar_size }}px;
    height: {{ section.settings.avatar_size }}px;
    border-radius: 999px;
    object-fit: cover;
    border: 2px solid var(--faq-bg);
    margin-left: -{{ section.settings.avatar_overlap }}px;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-avatars img:first-child {
    margin-left: 0;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-description {
    max-width: {{ section.settings.description_width }}px;
    margin: 0 0 {{ section.settings.description_bottom_spacing }}px 0;
    color: var(--faq-text);
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.45;
    font-weight: {{ section.settings.description_weight }};
  }

  #pureva-faq-{{ section.id }} .pureva-faq-button {
    width: 100%;
    max-width: {{ section.settings.button_width }}px;
    min-height: {{ section.settings.button_height }}px;
    padding: 0 24px;
    border-radius: 999px;
    border: 1px solid var(--faq-button-text);
    background: var(--faq-button-bg);
    color: var(--faq-button-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: {{ section.settings.button_text_size }}px;
    line-height: 1;
    font-weight: 700;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-button:hover {
    transform: translateY(-1px);
    opacity: 0.9;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-right {
    width: 100%;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-items {
    border-top: 1px solid var(--faq-border);
  }

  #pureva-faq-{{ section.id }} .pureva-faq-item {
    border-bottom: 1px solid var(--faq-border);
  }

  #pureva-faq-{{ section.id }} .pureva-faq-question {
    width: 100%;
    padding: {{ section.settings.question_padding_y }}px 0;
    border: none;
    background: transparent;
    color: var(--faq-text);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-question span:first-child {
    font-size: {{ section.settings.question_size }}px;
    line-height: 1.35;
    font-weight: {{ section.settings.question_weight }};
  }

  #pureva-faq-{{ section.id }} .pureva-faq-plus {
    flex: 0 0 auto;
    font-size: {{ section.settings.plus_size }}px;
    line-height: 1;
    font-weight: 500;
    color: var(--faq-text);
    transition: transform 0.25s ease;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-item.is-open .pureva-faq-plus {
    transform: rotate(45deg);
  }

  #pureva-faq-{{ section.id }} .pureva-faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-answer > div {
    overflow: hidden;
    color: var(--faq-muted);
    font-size: {{ section.settings.answer_size }}px;
    line-height: 1.55;
    font-weight: 500;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-item.is-open .pureva-faq-answer {
    grid-template-rows: 1fr;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-item.is-open .pureva-faq-answer > div {
    padding-bottom: {{ section.settings.answer_bottom_padding }}px;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefits {
    display: grid;
    grid-template-columns: repeat({{ section.settings.benefits_columns_desktop }}, 1fr);
    gap: {{ section.settings.benefits_gap }}px;
    margin-top: {{ section.settings.benefits_top_spacing }}px;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefit {
    position: relative;
    min-height: {{ section.settings.benefit_height }}px;
    padding: {{ section.settings.benefit_padding_y }}px {{ section.settings.benefit_padding_x }}px {{ section.settings.benefit_padding_y }}px {{ section.settings.benefit_icon_offset }}px;
    background: var(--faq-card-bg);
    color: var(--faq-text);
    display: flex;
    align-items: center;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefit-icon {
    position: absolute;
    left: -{{ section.settings.benefit_icon_overlap }}px;
    top: 50%;
    transform: translateY(-50%);
    width: {{ section.settings.benefit_icon_size }}px;
    height: {{ section.settings.benefit_icon_size }}px;
    border-radius: 999px;
    background: var(--faq-icon-bg);
    color: var(--faq-icon-color);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefit-icon svg {
    width: 55%;
    height: 55%;
    display: block;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefit-icon svg path {
    stroke: currentColor;
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefit strong {
    display: block;
    margin-bottom: 4px;
    font-size: {{ section.settings.benefit_title_size }}px;
    line-height: 1.25;
    font-weight: 500;
    color: var(--faq-text);
  }

  #pureva-faq-{{ section.id }} .pureva-faq-benefit p {
    margin: 0;
    color: var(--faq-text);
    font-size: {{ section.settings.benefit_text_size }}px;
    line-height: 1.35;
    font-weight: 400;
  }

  @media screen and (max-width: 989px) {
    #pureva-faq-{{ section.id }} {
      padding: var(--faq-mobile-padding-y) {{ section.settings.mobile_padding_x }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-container {
      display: flex;
      flex-direction: column;
      gap: {{ section.settings.mobile_gap }}px;
      align-items: stretch;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-left-header {
      margin-bottom: {{ section.settings.mobile_heading_bottom_spacing }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-avatars img {
      width: {{ section.settings.mobile_avatar_size }}px;
      height: {{ section.settings.mobile_avatar_size }}px;
      margin-left: -{{ section.settings.mobile_avatar_overlap }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-description {
      max-width: 100%;
      margin-bottom: {{ section.settings.mobile_description_bottom_spacing }}px;
      font-size: {{ section.settings.mobile_description_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-button {
      max-width: 100%;
      min-height: {{ section.settings.mobile_button_height }}px;
      font-size: {{ section.settings.mobile_button_text_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-question {
      padding: {{ section.settings.mobile_question_padding_y }}px 0;
      gap: 16px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-question span:first-child {
      font-size: {{ section.settings.mobile_question_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-plus {
      font-size: {{ section.settings.mobile_plus_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-answer > div {
      font-size: {{ section.settings.mobile_answer_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-benefits {
      grid-template-columns: 1fr;
      gap: {{ section.settings.mobile_benefits_gap }}px;
      margin-top: {{ section.settings.mobile_benefits_top_spacing }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-benefit {
      min-height: {{ section.settings.mobile_benefit_height }}px;
      padding: {{ section.settings.mobile_benefit_padding_y }}px {{ section.settings.mobile_benefit_padding_x }}px {{ section.settings.mobile_benefit_padding_y }}px {{ section.settings.mobile_benefit_icon_offset }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-benefit-icon {
      left: -{{ section.settings.mobile_benefit_icon_overlap }}px;
      width: {{ section.settings.mobile_benefit_icon_size }}px;
      height: {{ section.settings.mobile_benefit_icon_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-benefit strong {
      font-size: {{ section.settings.mobile_benefit_title_size }}px;
    }

    #pureva-faq-{{ section.id }} .pureva-faq-benefit p {
      font-size: {{ section.settings.mobile_benefit_text_size }}px;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector('#pureva-faq-{{ section.id }}');
    if (!section) return;

    const items = Array.from(section.querySelectorAll('.pureva-faq-item'));

    items.forEach((item) => {
      const button = item.querySelector('.pureva-faq-question');
      if (!button) return;

      button.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');

        {% if section.settings.close_others %}
          items.forEach((otherItem) => {
            otherItem.classList.remove('is-open');
            const otherButton = otherItem.querySelector('.pureva-faq-question');
            if (otherButton) otherButton.setAttribute('aria-expanded', 'false');
          });
        {% endif %}

        item.classList.toggle('is-open', !isOpen);
        button.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    {% if section.settings.open_first %}
      const firstItem = items[0];
      const firstButton = firstItem?.querySelector('.pureva-faq-question');
      if (firstItem && firstButton) {
        firstItem.classList.add('is-open');
        firstButton.setAttribute('aria-expanded', 'true');
      }
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Pureva FAQ",
  "settings": [
    {
      "type": "header",
      "content": "Colonne gauche"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "F.A.Q"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Une question ? Nous avons la réponse ! Notre équipe d’experts est là pour vous, du lundi au samedi, de 9h à 18h."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte bouton",
      "default": "sav@puurefrance.fr"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien bouton"
    },
    {
      "type": "image_picker",
      "id": "avatar_1",
      "label": "Avatar 1"
    },
    {
      "type": "text",
      "id": "avatar_alt_1",
      "label": "Texte alternatif avatar 1",
      "default": "Expert support 1"
    },
    {
      "type": "image_picker",
      "id": "avatar_2",
      "label": "Avatar 2"
    },
    {
      "type": "text",
      "id": "avatar_alt_2",
      "label": "Texte alternatif avatar 2",
      "default": "Expert support 2"
    },
    {
      "type": "image_picker",
      "id": "avatar_3",
      "label": "Avatar 3"
    },
    {
      "type": "text",
      "id": "avatar_alt_3",
      "label": "Texte alternatif avatar 3",
      "default": "Expert support 3"
    },
    {
      "type": "header",
      "content": "Comportement FAQ"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Ouvrir la première question par défaut",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "Fermer les autres questions à l’ouverture",
      "default": true
    },
    {
      "type": "textarea",
      "id": "check_icon_svg",
      "label": "Icône check SVG",
      "default": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M20 6L9 17l-5-5'/></svg>"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Fond section",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#08164C"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Texte réponse",
      "default": "#4E5878"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bordures FAQ",
      "default": "#D8DCE6"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fond cartes avantages",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Fond icône avantage",
      "default": "#14244D"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur icône avantage",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Fond bouton",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Texte / bordure bouton",
      "default": "#14244D"
    },
    {
      "type": "header",
      "content": "Dimensions ordinateur"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximale",
      "min": 900,
      "max": 1600,
      "step": 20,
      "default": 1180,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desktop_padding_y",
      "label": "Marge haut/bas",
      "min": 40,
      "max": 180,
      "step": 5,
      "default": 95,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desktop_padding_x",
      "label": "Marge gauche/droite",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "left_column_width",
      "label": "Largeur colonne gauche",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "right_column_width",
      "label": "Largeur colonne droite",
      "min": 4,
      "max": 9,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "desktop_gap",
      "label": "Espace entre colonnes",
      "min": 40,
      "max": 180,
      "step": 5,
      "default": 95,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typographie gauche"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille titre",
      "min": 22,
      "max": 52,
      "step": 1,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse titre",
      "default": "800",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" },
        { "value": "900", "label": "Black" }
      ]
    },
    {
      "type": "range",
      "id": "heading_bottom_spacing",
      "label": "Espace titre / texte",
      "min": 10,
      "max": 45,
      "step": 1,
      "default": 25,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Taille description",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "description_weight",
      "label": "Graisse description",
      "default": "500",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ]
    },
    {
      "type": "range",
      "id": "description_width",
      "label": "Largeur description",
      "min": 260,
      "max": 560,
      "step": 10,
      "default": 470,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "description_bottom_spacing",
      "label": "Espace description / bouton",
      "min": 18,
      "max": 50,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "label": "Taille avatars",
      "min": 22,
      "max": 48,
      "step": 1,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "avatar_overlap",
      "label": "Chevauchement avatars",
      "min": 0,
      "max": 18,
      "step": 1,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Bouton"
    },
    {
      "type": "range",
      "id": "button_width",
      "label": "Largeur bouton",
      "min": 220,
      "max": 520,
