      "min": 0,
      "max": 24,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typographie ordinateur"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille titre",
      "min": 28,
      "max": 76,
      "step": 1,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_width",
      "label": "Largeur titre",
      "min": 280,
      "max": 720,
      "step": 10,
      "default": 470,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse titre",
      "default": "400",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
