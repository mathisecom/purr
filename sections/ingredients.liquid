<section
  id="pureva-layers-{{ section.id }}"
  class="pureva-layers-section"
  style="
    --pl-bg: {{ section.settings.section_background }};
    --pl-text: {{ section.settings.text_color }};
    --pl-muted: {{ section.settings.muted_text_color }};
    --pl-badge-bg: {{ section.settings.badge_background }};
    --pl-badge-text: {{ section.settings.badge_text_color }};
    --pl-card-bg: {{ section.settings.card_background }};
    --pl-card-text: {{ section.settings.card_text_color }};
    --pl-border: {{ section.settings.border_color }};
    --pl-button-bg: {{ section.settings.button_background }};
    --pl-button-text: {{ section.settings.button_text_color }};
    --pl-max-width: {{ section.settings.max_width }}px;
    --pl-padding-y: {{ section.settings.desktop_padding_y }}px;
    --pl-mobile-padding-y: {{ section.settings.mobile_padding_y }}px;
  "
>
  <div class="pureva-layers-container">

    {% if section.settings.badge_text != blank %}
      <div class="pureva-layers-badge">
        {{ section.settings.badge_text }}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="pureva-layers-heading">
        {{ section.settings.heading | newline_to_br }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="pureva-layers-subheading">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    {% if section.settings.certification_text != blank %}
      <div class="pureva-layers-certification">
        {% if section.settings.certification_logo != blank %}
          <div class="pureva-certification-logo">
            <img
              src="{{ section.settings.certification_logo | image_url: width: 160 }}"
              alt="{{ section.settings.certification_logo_alt | escape }}"
              loading="lazy"
            >
          </div>
        {% else %}
          <div class="pureva-certification-logo pureva-certification-logo-text">
            {{ section.settings.certification_logo_text }}
          </div>
        {% endif %}

        <div class="pureva-certification-text">
          {{ section.settings.certification_text }}
        </div>
      </div>
    {% endif %}

    <div class="pureva-layers-slider-wrap">
      <div class="pureva-layers-slider" data-slider>
        {% for block in section.blocks %}
          <article
            class="pureva-layer-card {% if forloop.index == 3 %}is-active{% endif %}"
            data-card
            {{ block.shopify_attributes }}
          >
            <div class="pureva-layer-image-wrap">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  alt="{{ block.settings.image_alt | escape }}"
                  class="pureva-layer-image"
                  loading="lazy"
                >
              {% else %}
                <div class="pureva-layer-placeholder">
                  Image
                </div>
              {% endif %}

              <div class="pureva-layer-info">
                {% if block.settings.step != blank %}
                  <span class="pureva-layer-step">
                    {{ block.settings.step }}
                  </span>
                {% endif %}

                {% if block.settings.title != blank %}
                  <h3>
                    {{ block.settings.title }}
                  </h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <p>
                    {{ block.settings.text }}
                  </p>
                {% endif %}
              </div>

              {% if block.settings.show_arrow %}
                <div class="pureva-layer-open-icon">
                  {{ section.settings.card_arrow_svg }}
                </div>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>

      <div class="pureva-layers-controls">
        <button class="pureva-layers-arrow" type="button" data-prev aria-label="Carte précédente">
          {{ section.settings.prev_arrow_svg }}
        </button>

        <button class="pureva-layers-arrow" type="button" data-next aria-label="Carte suivante">
          {{ section.settings.next_arrow_svg }}
        </button>
      </div>
    </div>

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800;900&display=swap');

  #pureva-layers-{{ section.id }} {
    width: 100%;
    background: var(--pl-bg);
    color: var(--pl-text);
    font-family: 'Instrument Sans', Arial, Helvetica, sans-serif;
    padding: var(--pl-padding-y) {{ section.settings.desktop_padding_x }}px;
    overflow: hidden;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-container {
    width: 100%;
    max-width: var(--pl-max-width);
    margin: 0 auto;
    text-align: center;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ section.settings.badge_bottom_spacing }}px;
    padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px;
    border-radius: {{ section.settings.badge_radius }}px;
    background: var(--pl-badge-bg);
    color: var(--pl-badge-text);
    font-size: {{ section.settings.badge_size }}px;
    line-height: 1;
    font-weight: 800;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-heading {
    max-width: {{ section.settings.heading_width }}px;
    margin: 0 auto;
    color: var(--pl-text);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.08;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: -1.2px;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-subheading {
    max-width: {{ section.settings.subheading_width }}px;
    margin: {{ section.settings.subheading_top_spacing }}px auto 0 auto;
    color: var(--pl-muted);
    font-size: {{ section.settings.subheading_size }}px;
    line-height: 1.4;
    font-weight: 500;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-certification {
    width: 100%;
    max-width: {{ section.settings.certification_width }}px;
    margin: {{ section.settings.certification_top_spacing }}px auto 0 auto;
    padding: {{ section.settings.certification_padding_y }}px {{ section.settings.certification_padding_x }}px;
    border: 1px solid var(--pl-border);
    border-radius: {{ section.settings.certification_radius }}px;
    background: {{ section.settings.certification_background }};
    display: grid;
    grid-template-columns: {{ section.settings.certification_logo_size }}px 1fr;
    gap: {{ section.settings.certification_gap }}px;
    align-items: center;
    text-align: left;
  }

  #pureva-layers-{{ section.id }} .pureva-certification-logo {
    width: {{ section.settings.certification_logo_size }}px;
    height: {{ section.settings.certification_logo_size }}px;
    border-radius: 999px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #pureva-layers-{{ section.id }} .pureva-certification-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #pureva-layers-{{ section.id }} .pureva-certification-logo-text {
    background: #0068a9;
    color: #ffffff;
    font-size: 24px;
    font-weight: 900;
  }

  #pureva-layers-{{ section.id }} .pureva-certification-text {
    color: var(--pl-muted);
    font-size: {{ section.settings.certification_text_size }}px;
    line-height: 1.45;
    font-weight: 500;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-slider-wrap {
    margin-top: {{ section.settings.slider_top_spacing }}px;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-slider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.card_gap }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: {{ section.settings.slider_padding_y }}px 0;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-slider::-webkit-scrollbar {
    display: none;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-card {
    flex: 0 0 {{ section.settings.side_card_width }}px;
    scroll-snap-align: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: {{ section.settings.side_card_opacity | divided_by: 100.0 }};
  }

  #pureva-layers-{{ section.id }} .pureva-layer-card.is-active {
    flex-basis: {{ section.settings.active_card_width }}px;
    opacity: 1;
    transform: translateY(-{{ section.settings.active_card_lift }}px);
  }

  #pureva-layers-{{ section.id }} .pureva-layer-image-wrap {
    position: relative;
    width: 100%;
    height: {{ section.settings.side_card_height }}px;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: #e9edf3;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-card.is-active .pureva-layer-image-wrap {
    height: {{ section.settings.active_card_height }}px;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-image,
  #pureva-layers-{{ section.id }} .pureva-layer-placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-image {
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }

  #pureva-layers-{{ section.id }} .pureva-layer-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pl-muted);
    font-weight: 700;
    background: #dde3ec;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-info {
    position: absolute;
    top: {{ section.settings.info_position_top }}px;
    left: {{ section.settings.info_position_left }}px;
    right: {{ section.settings.info_position_right }}px;
    padding: {{ section.settings.info_padding_y }}px {{ section.settings.info_padding_x }}px;
    border-radius: {{ section.settings.info_radius }}px;
    background: var(--pl-card-bg);
    color: var(--pl-card-text);
    text-align: left;
    box-shadow: 0 10px 30px rgba(11, 22, 45, 0.08);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-card.is-active .pureva-layer-info {
    opacity: 1;
    transform: translateY(0);
  }

  #pureva-layers-{{ section.id }} .pureva-layer-step {
    display: block;
    margin-bottom: 4px;
    color: var(--pl-muted);
    font-size: {{ section.settings.step_size }}px;
    line-height: 1;
    font-weight: 600;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-info h3 {
    margin: 0 0 8px 0;
    color: var(--pl-card-text);
    font-size: {{ section.settings.card_title_size }}px;
    line-height: 1.05;
    font-weight: 900;
    letter-spacing: -0.2px;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-info p {
    margin: 0;
    color: var(--pl-muted);
    font-size: {{ section.settings.card_text_size }}px;
    line-height: 1.38;
    font-weight: 600;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-open-icon {
    position: absolute;
    top: {{ section.settings.open_icon_top }}px;
    right: {{ section.settings.open_icon_right }}px;
    width: {{ section.settings.open_icon_size }}px;
    height: {{ section.settings.open_icon_size }}px;
    border-radius: {{ section.settings.open_icon_radius }}px;
    background: var(--pl-button-bg);
    color: var(--pl-button-text);
    display: none;
    align-items: center;
    justify-content: center;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-card.is-active .pureva-layer-open-icon {
    display: flex;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-open-icon svg,
  #pureva-layers-{{ section.id }} .pureva-layers-arrow svg {
    width: 48%;
    height: 48%;
    display: block;
  }

  #pureva-layers-{{ section.id }} .pureva-layer-open-icon svg path,
  #pureva-layers-{{ section.id }} .pureva-layers-arrow svg path {
    stroke: currentColor;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ section.settings.controls_gap }}px;
    margin-top: {{ section.settings.controls_top_spacing }}px;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-arrow {
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border: none;
    border-radius: 999px;
    background: var(--pl-button-bg);
    color: var(--pl-button-text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(11, 22, 45, 0.08);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #pureva-layers-{{ section.id }} .pureva-layers-arrow:hover {
    transform: translateY(-1px);
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    #pureva-layers-{{ section.id }} {
      padding: var(--pl-mobile-padding-y) {{ section.settings.mobile_padding_x }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-badge {
      margin-bottom: {{ section.settings.mobile_badge_bottom_spacing }}px;
      padding: {{ section.settings.mobile_badge_padding_y }}px {{ section.settings.mobile_badge_padding_x }}px;
      border-radius: {{ section.settings.mobile_badge_radius }}px;
      font-size: {{ section.settings.mobile_badge_size }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-heading {
      max-width: {{ section.settings.mobile_heading_width }}px;
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: 1.08;
      letter-spacing: -0.8px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-subheading {
      max-width: {{ section.settings.mobile_subheading_width }}px;
      margin-top: {{ section.settings.mobile_subheading_top_spacing }}px;
      font-size: {{ section.settings.mobile_subheading_size }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-certification {
      max-width: 100%;
      margin-top: {{ section.settings.mobile_certification_top_spacing }}px;
      padding: {{ section.settings.mobile_certification_padding_y }}px {{ section.settings.mobile_certification_padding_x }}px;
      border-radius: {{ section.settings.mobile_certification_radius }}px;
      grid-template-columns: {{ section.settings.mobile_certification_logo_size }}px 1fr;
      gap: {{ section.settings.mobile_certification_gap }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-certification-logo {
      width: {{ section.settings.mobile_certification_logo_size }}px;
      height: {{ section.settings.mobile_certification_logo_size }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-certification-logo-text {
      font-size: 19px;
    }

    #pureva-layers-{{ section.id }} .pureva-certification-text {
      font-size: {{ section.settings.mobile_certification_text_size }}px;
      line-height: 1.45;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-slider-wrap {
      margin-top: {{ section.settings.mobile_slider_top_spacing }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-slider {
      justify-content: flex-start;
      gap: {{ section.settings.mobile_card_gap }}px;
      margin-left: -{{ section.settings.mobile_padding_x }}px;
      margin-right: -{{ section.settings.mobile_padding_x }}px;
      padding: {{ section.settings.mobile_slider_padding_y }}px {{ section.settings.mobile_slider_side_padding }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-card,
    #pureva-layers-{{ section.id }} .pureva-layer-card.is-active {
      flex: 0 0 {{ section.settings.mobile_card_width }}px;
      opacity: 1;
      transform: none;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-image-wrap,
    #pureva-layers-{{ section.id }} .pureva-layer-card.is-active .pureva-layer-image-wrap {
      height: {{ section.settings.mobile_card_height }}px;
      border-radius: {{ section.settings.mobile_card_radius }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-info {
      top: {{ section.settings.mobile_info_position_top }}px;
      left: {{ section.settings.mobile_info_position_left }}px;
      right: {{ section.settings.mobile_info_position_right }}px;
      padding: {{ section.settings.mobile_info_padding_y }}px {{ section.settings.mobile_info_padding_x }}px;
      border-radius: {{ section.settings.mobile_info_radius }}px;
      opacity: 1;
      transform: none;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-step {
      font-size: {{ section.settings.mobile_step_size }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-info h3 {
      font-size: {{ section.settings.mobile_card_title_size }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-info p {
      font-size: {{ section.settings.mobile_card_text_size }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layer-open-icon,
    #pureva-layers-{{ section.id }} .pureva-layer-card.is-active .pureva-layer-open-icon {
      display: flex;
      width: {{ section.settings.mobile_open_icon_size }}px;
      height: {{ section.settings.mobile_open_icon_size }}px;
      top: {{ section.settings.mobile_open_icon_top }}px;
      right: {{ section.settings.mobile_open_icon_right }}px;
      border-radius: {{ section.settings.mobile_open_icon_radius }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-controls {
      margin-top: {{ section.settings.mobile_controls_top_spacing }}px;
    }

    #pureva-layers-{{ section.id }} .pureva-layers-arrow {
      width: {{ section.settings.mobile_arrow_size }}px;
      height: {{ section.settings.mobile_arrow_size }}px;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector('#pureva-layers-{{ section.id }}');
    if (!section) return;

    const slider = section.querySelector('[data-slider]');
    const cards = Array.from(section.querySelectorAll('[data-card]'));
    const prev = section.querySelector('[data-prev]');
    const next = section.querySelector('[data-next]');

    if (!slider || !cards.length) return;

    let activeIndex = Math.min(2, cards.length - 1);

    const setActive = (index, scroll = true) => {
      activeIndex = (index + cards.length) % cards.length;

      cards.forEach((card, i) => {
        card.classList.toggle('is-active', i === activeIndex);
      });

      if (scroll) {
        cards[activeIndex].scrollIntoView({
          behavior: 'smooth',
          inline: 'center',
          block: 'nearest'
        });
      }
    };

    prev?.addEventListener('click', () => {
      setActive(activeIndex - 1);
    });

    next?.addEventListener('click', () => {
      setActive(activeIndex + 1);
    });

    cards.forEach((card, index) => {
      card.addEventListener('click', () => {
        setActive(index);
      });
    });

    let scrollTimer;
    slider.addEventListener('scroll', () => {
      window.clearTimeout(scrollTimer);

      scrollTimer = window.setTimeout(() => {
        const sliderRect = slider.getBoundingClientRect();
        const sliderCenter = sliderRect.left + sliderRect.width / 2;

        let closestIndex = 0;
        let closestDistance = Infinity;

        cards.forEach((card, index) => {
          const cardRect = card.getBoundingClientRect();
          const cardCenter = cardRect.left + cardRect.width / 2;
          const distance = Math.abs(sliderCenter - cardCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        setActive(closestIndex, false);
      }, 80);
    });

    setActive(activeIndex, false);
  })();
</script>

{% schema %}
{
  "name": "Pureva couches filtration",
  "settings": [
    {
      "type": "header",
      "content": "En-tête"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "default": "Que contiennent nos cartouches ?"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre",
      "default": "La nature filtre l'eau par couches. Nous aussi"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Inspiré par la nature, validé par la science"
    },
    {
      "type": "header",
      "content": "Certification"
    },
    {
      "type": "image_picker",
      "id": "certification_logo",
      "label": "Logo certification"
    },
    {
      "type": "text",
      "id": "certification_logo_alt",
      "label": "Texte alternatif du logo",
      "default": "Certification NSF"
    },
    {
      "type": "text",
      "id": "certification_logo_text",
      "label": "Texte logo si aucune image",
      "default": "NSF."
    },
    {
      "type": "textarea",
      "id": "certification_text",
      "label": "Texte certification",
      "default": "Les composants de la cartouche Pure® sont testés et certifiés par NSF International selon la norme NSF/ANSI 42 pour la sécurité des matériaux. La cartouche Pure® 3.0 est spécifiquement formulée pour les contaminants présents dans l'eau du robinet européenne."
    },
    {
      "type": "header",
      "content": "Icônes SVG"
    },
    {
      "type": "textarea",
      "id": "card_arrow_svg",
      "label": "Icône flèche dans la carte",
      "default": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M7 17L17 7'/><path d='M9 7h8v8'/></svg>"
    },
    {
      "type": "textarea",
      "id": "prev_arrow_svg",
      "label": "Icône bouton précédent",
      "default": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M15 18l-6-6 6-6'/></svg>"
    },
    {
      "type": "textarea",
      "id": "next_arrow_svg",
      "label": "Icône bouton suivant",
      "default": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M9 18l6-6-6-6'/></svg>"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Fond section",
      "default": "#F7F7F8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#061A44"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Texte secondaire",
      "default": "#728096"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Fond badge",
      "default": "#E9EEFF"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Texte badge",
      "default": "#061A44"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fond carte texte",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Texte carte",
      "default": "#061A44"
    },
    {
