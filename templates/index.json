        "liquid_Kf6Dyr": {
          "type": "liquid",
          "settings": {
            "liquid": "<div class=\"product-info__liquid\">\n            <!-- VALORISE — Livraison dynamique (court, mobile, point animé) -->\n<div class=\"valo-delivery\" id=\"valoDelivery\" role=\"status\">\n  <style>\n    .valo-delivery{\n      display:flex; align-items:center; gap:6px;\n      justify-content:center;\n      font-size:12px; font-weight:500; color:#111;\n      background:transparent; padding:4px 0;\n      white-space:nowrap;\n    }\n    .valo-delivery .dot{\n      width:9px; height:9px; border-radius:9999px;\n      background:rgba(34,197,94,.25);\n      box-shadow:0 0 0 0 rgba(34,197,94,.35);\n      animation:valoPulse 1.6s infinite;\n      flex-shrink:0;\n    }\n    .valo-delivery b{\n      color:#4378FF; font-weight:600;\n    }\n    @keyframes valoPulse{\n      0%{box-shadow:0 0 0 0 rgba(34,197,94,.35);}\n      70%{box-shadow:0 0 0 6px rgba(34,197,94,0);}\n      100%{box-shadow:0 0 0 0 rgba(34,197,94,0);}\n    }\n    @media(max-width:420px){\n      .valo-delivery{font-size:11px; gap:5px; white-space:normal;}\n    }\n  </style>\n\n  <span class=\"dot\" aria-hidden=\"true\"></span>\n  <span id=\"valoDeliveryText\">En stock · Livraison express <b>lun 1 juin</b> – <b>mar 2 juin</b></span>\n\n  <script>\n    (function(){\n      const el = document.getElementById(\"valoDeliveryText\");\n      const today = new Date();\n\n      // ajoute des jours en sautant le dimanche\n      function addDaysSkipSunday(date, days){\n        const d = new Date(date);\n        let added = 0;\n        while(added < days){\n          d.setDate(d.getDate() + 1);\n          if (d.getDay() !== 0) added++; // 0 = dimanche\n        }\n        return d;\n      }\n\n      // expédition le lendemain\n      const ship = new Date(today);\n      ship.setDate(ship.getDate() + 1);\n      if (ship.getDay() === 0) ship.setDate(ship.getDate() + 1); // si dimanche → lundi\n\n      // fenêtre 48–72h ouvrées\n      const min = addDaysSkipSunday(ship, 2);\n      const max = addDaysSkipSunday(ship, 3);\n\n      const opt = { weekday: \"short\", day: \"numeric\", month: \"short\" };\n      const s1 = min.toLocaleDateString(\"fr-FR\", opt).replace(\".\", \"\");\n      const s2 = max.toLocaleDateString(\"fr-FR\", opt).replace(\".\", \"\");\n\n      // version courte pour mobile\n      el.innerHTML = `En stock · Livraison Express <b>${s1}</b> – <b>${s2}</b>`;\n    })();\n  </script>\n</div>\n          </div>"
          }
        },
