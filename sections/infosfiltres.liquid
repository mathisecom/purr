<section
  id="pureva-filter-{{ section.id }}"
  class="pureva-filter-section"
  style="
    --pf-bg: {{ section.settings.section_background }};
    --pf-card-bg: {{ section.settings.image_card_background }};
    --pf-blue: {{ section.settings.blue_background }};
    --pf-text: {{ section.settings.text_color }};
    --pf-blue-text: {{ section.settings.blue_text_color }};
    --pf-muted: {{ section.settings.muted_text_color }};
    --pf-border: {{ section.settings.accordion_border_color }};
    --pf-radius: {{ section.settings.card_radius }}px;
    --pf-max-width: {{ section.settings.max_width }}px;
  "
>
  <div class="pureva-filter-container">
    <div class="pureva-filter-image-card">
      {% if section.settings.heading != blank %}
        <h2 class="pureva-filter-heading">
          {{ section.settings.heading | newline_to_br }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="pureva-filter-subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      <div class="pureva-filter-product-wrap">
        {% if section.settings.product_image != blank %}
          <img
            src="{{ section.settings.product_image | image_url: width: 900 }}"
            alt="{{ section.settings.product_image_alt | escape }}"
            class="pureva-filter-product-image"
            loading="lazy"
          >
        {% else %}
          <div class="pureva-filter-placeholder">
            Ajoute l’image de la cartouche
          </div>
        {% endif %}

        {% if section.settings.left_label != blank %}
          <span class="pureva-filter-label pureva-filter-label-left">
            {{ section.settings.left_label }}
          </span>
        {% endif %}

        {% if section.settings.right_label != blank %}
          <span class="pureva-filter-label pureva-filter-label-right">
            {{ section.settings.right_label }}
          </span>
        {% endif %}
      </div>
    </div>

    <div class="pureva-filter-accordion-card">
      {% for block in section.blocks %}
        <div class="pureva-filter-item" {{ block.shopify_attributes }}>
          <button class="pureva-filter-question" type="button" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span class="pureva-filter-plus">+</span>
          </button>

          {% if block.settings.answer != blank %}
            <div class="pureva-filter-answer">
              <div>
                {{ block.settings.answer }}
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800;900&display=swap');

  #pureva-filter-{{ section.id }} {
    width: 100%;
    background: var(--pf-bg);
    padding: {{ section.settings.desktop_padding_y }}px {{ section.settings.desktop_padding_x }}px;
    font-family: 'Instrument Sans', Arial, Helvetica, sans-serif;
    overflow: hidden;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-container {
    width: 100%;
    max-width: var(--pf-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: {{ section.settings.image_column_width }}fr {{ section.settings.accordion_column_width }}fr;
    gap: {{ section.settings.desktop_gap }}px;
    align-items: center;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-image-card {
    position: relative;
    min-height: {{ section.settings.image_card_height }}px;
    padding: {{ section.settings.image_card_padding_top }}px {{ section.settings.image_card_padding_x }}px 0;
    border-radius: var(--pf-radius);
    background: var(--pf-card-bg);
    color: var(--pf-text);
    overflow: hidden;
    text-align: center;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-heading {
    max-width: {{ section.settings.heading_width }}px;
    margin: 0 auto;
    color: var(--pf-text);
    font-size: {{ section.settings.heading_size }}px;
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: -1.2px;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-subheading {
    max-width: {{ section.settings.subheading_width }}px;
    margin: {{ section.settings.subheading_top_spacing }}px auto 0;
    color: var(--pf-muted);
    font-size: {{ section.settings.subheading_size }}px;
    line-height: 1.28;
    font-weight: {{ section.settings.subheading_weight }};
  }

  #pureva-filter-{{ section.id }} .pureva-filter-product-wrap {
    position: relative;
    width: 100%;
    height: {{ section.settings.product_area_height }}px;
    margin-top: {{ section.settings.product_top_spacing }}px;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-product-image {
    position: absolute;
    left: 50%;
    bottom: {{ section.settings.product_bottom_offset }}px;
    transform: translateX(-50%);
    width: {{ section.settings.product_image_width }}px;
    max-width: 100%;
    height: auto;
    display: block;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-placeholder {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 260px;
    height: 360px;
    border-radius: 20px;
    background: #eef2f7;
    color: var(--pf-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-label {
    position: absolute;
    top: {{ section.settings.label_top }}px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.label_padding_y }}px {{ section.settings.label_padding_x }}px;
    border-radius: {{ section.settings.label_radius }}px;
    background: var(--pf-blue);
    color: var(--pf-blue-text);
    font-size: {{ section.settings.label_size }}px;
    line-height: 1;
    font-weight: 700;
    box-shadow: 0 8px 18px rgba(39, 100, 255, 0.18);
  }

  #pureva-filter-{{ section.id }} .pureva-filter-label-left {
    left: {{ section.settings.left_label_position }}%;
    transform: translateX(-50%);
  }

  #pureva-filter-{{ section.id }} .pureva-filter-label-right {
    right: {{ section.settings.right_label_position }}%;
    transform: translateX(50%);
  }

  #pureva-filter-{{ section.id }} .pureva-filter-accordion-card {
    width: 100%;
    border-radius: {{ section.settings.accordion_radius }}px;
    background: var(--pf-blue);
    color: var(--pf-blue-text);
    padding: {{ section.settings.accordion_padding_y }}px {{ section.settings.accordion_padding_x }}px;
    box-shadow: {{ section.settings.accordion_shadow }};
  }

  #pureva-filter-{{ section.id }} .pureva-filter-item {
    border-bottom: 1px solid var(--pf-border);
  }

  #pureva-filter-{{ section.id }} .pureva-filter-item:last-child {
    border-bottom: none;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-question {
    width: 100%;
    min-height: {{ section.settings.question_height }}px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--pf-blue-text);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-question span:first-child {
    font-size: {{ section.settings.question_size }}px;
    line-height: 1.25;
    font-weight: {{ section.settings.question_weight }};
  }

  #pureva-filter-{{ section.id }} .pureva-filter-plus {
    flex: 0 0 auto;
    width: {{ section.settings.plus_size }}px;
    height: {{ section.settings.plus_size }}px;
    border-radius: 999px;
    background: rgba(255,255,255,0.14);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.plus_text_size }}px;
    line-height: 1;
    font-weight: 400;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-item.is-open .pureva-filter-plus {
    transform: rotate(45deg);
    background: rgba(255,255,255,0.22);
  }

  #pureva-filter-{{ section.id }} .pureva-filter-answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-answer > div {
    overflow: hidden;
    color: var(--pf-blue-text);
    opacity: 0.82;
    font-size: {{ section.settings.answer_size }}px;
    line-height: 1.45;
    font-weight: 500;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-item.is-open .pureva-filter-answer {
    grid-template-rows: 1fr;
  }

  #pureva-filter-{{ section.id }} .pureva-filter-item.is-open .pureva-filter-answer > div {
    padding-bottom: {{ section.settings.answer_bottom_padding }}px;
  }

  @media screen and (max-width: 989px) {
    #pureva-filter-{{ section.id }} {
      padding: {{ section.settings.mobile_padding_y }}px {{ section.settings.mobile_padding_x }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-container {
      display: flex;
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-image-card {
      min-height: {{ section.settings.mobile_image_card_height }}px;
      padding: {{ section.settings.mobile_image_card_padding_top }}px {{ section.settings.mobile_image_card_padding_x }}px 0;
      border-radius: {{ section.settings.mobile_card_radius }}px {{ section.settings.mobile_card_radius }}px 0 0;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-heading {
      max-width: {{ section.settings.mobile_heading_width }}px;
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: {{ section.settings.mobile_heading_line_height | divided_by: 100.0 }};
      letter-spacing: -0.7px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-subheading {
      max-width: {{ section.settings.mobile_subheading_width }}px;
      margin-top: {{ section.settings.mobile_subheading_top_spacing }}px;
      font-size: {{ section.settings.mobile_subheading_size }}px;
      line-height: 1.25;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-product-wrap {
      height: {{ section.settings.mobile_product_area_height }}px;
      margin-top: {{ section.settings.mobile_product_top_spacing }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-product-image {
      width: {{ section.settings.mobile_product_image_width }}px;
      bottom: {{ section.settings.mobile_product_bottom_offset }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-label {
      top: {{ section.settings.mobile_label_top }}px;
      padding: {{ section.settings.mobile_label_padding_y }}px {{ section.settings.mobile_label_padding_x }}px;
      border-radius: {{ section.settings.mobile_label_radius }}px;
      font-size: {{ section.settings.mobile_label_size }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-label-left {
      left: {{ section.settings.mobile_left_label_position }}%;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-label-right {
      right: {{ section.settings.mobile_right_label_position }}%;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-accordion-card {
      margin-top: {{ section.settings.mobile_accordion_overlap }}px;
      border-radius: {{ section.settings.mobile_accordion_radius }}px;
      padding: {{ section.settings.mobile_accordion_padding_y }}px {{ section.settings.mobile_accordion_padding_x }}px;
      position: relative;
      z-index: 3;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-question {
      min-height: {{ section.settings.mobile_question_height }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-question span:first-child {
      font-size: {{ section.settings.mobile_question_size }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-plus {
      width: {{ section.settings.mobile_plus_size }}px;
      height: {{ section.settings.mobile_plus_size }}px;
      font-size: {{ section.settings.mobile_plus_text_size }}px;
    }

    #pureva-filter-{{ section.id }} .pureva-filter-answer > div {
      font-size: {{ section.settings.mobile_answer_size }}px;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector('#pureva-filter-{{ section.id }}');
    if (!section) return;

    const items = Array.from(section.querySelectorAll('.pureva-filter-item'));

    items.forEach((item) => {
      const button = item.querySelector('.pureva-filter-question');
      if (!button) return;

      button.addEventListener('click', () => {
        const isOpen = item.classList.contains('is-open');

        {% if section.settings.close_others %}
          items.forEach((other) => {
            other.classList.remove('is-open');
            const otherButton = other.querySelector('.pureva-filter-question');
            if (otherButton) otherButton.setAttribute('aria-expanded', 'false');
          });
        {% endif %}

        item.classList.toggle('is-open', !isOpen);
        button.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    {% if section.settings.open_first %}
      const first = items[0];
      const firstButton = first?.querySelector('.pureva-filter-question');

      if (first && firstButton) {
        first.classList.add('is-open');
        firstButton.setAttribute('aria-expanded', 'true');
      }
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Pureva filtration liste",
  "settings": [
    {
      "type": "header",
      "content": "Image et textes"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre",
      "default": "Nous filtrons l’eau.\nPour que votre corps n’ait pas à le faire."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Les cartouches Puure® 3.0 sont conçues pour réduire plus de 150 contaminants — dont les PFAS, le chlore, les microplastiques, les pesticides et les métaux lourds."
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Image de la cartouche"
    },
    {
      "type": "text",
      "id": "product_image_alt",
      "label": "Texte alternatif image",
      "default": "Cartouche filtrante avant après"
    },
    {
      "type": "text",
      "id": "left_label",
      "label": "Label gauche",
      "default": "Jour 1"
    },
    {
      "type": "text",
      "id": "right_label",
      "label": "Label droite",
      "default": "Jour 90"
    },
    {
      "type": "header",
      "content": "Comportement accordéon"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Ouvrir la première ligne par défaut",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "Fermer les autres lignes à l’ouverture",
      "default": true
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Fond extérieur",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "image_card_background",
      "label": "Fond carte image",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "blue_background",
      "label": "Fond bleu",
      "default": "#2764FF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#2764FF"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Texte secondaire",
      "default": "#2764FF"
    },
    {
      "type": "color",
      "id": "blue_text_color",
      "label": "Texte sur fond bleu",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accordion_border_color",
      "label": "Séparateurs accordéon",
      "default": "rgba(255,255,255,0.14)"
    },
    {
      "type": "header",
      "content": "Dimensions desktop"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximale",
      "min": 900,
      "max": 1800,
      "step": 20,
      "default": 1120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desktop_padding_y",
      "label": "Marge haut/bas desktop",
      "min": 30,
      "max": 140,
      "step": 5,
      "default": 45,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desktop_padding_x",
      "label": "Marge gauche/droite desktop",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "desktop_gap",
      "label": "Espace entre les deux blocs",
      "min": 30,
      "max": 120,
      "step": 5,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_column_width",
      "label": "Largeur colonne image",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "accordion_column_width",
      "label": "Largeur colonne accordéon",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "image_card_height",
      "label": "Hauteur carte image",
      "min": 420,
      "max": 720,
      "step": 10,
      "default": 560,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arrondi carte image",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_card_padding_top",
      "label": "Padding haut carte image",
      "min": 20,
      "max": 90,
      "step": 5,
      "default": 35,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_card_padding_x",
      "label": "Padding horizontal carte image",
      "min": 20,
      "max": 70,
      "step": 5,
      "default": 35,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "product_area_height",
      "label": "Hauteur zone produit",
      "min": 280,
      "max": 520,
      "step": 10,
      "default": 390,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "product_image_width",
      "label": "Largeur image produit",
      "min": 220,
      "max": 460,
      "step": 10,
      "default": 340,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "product_top_spacing",
      "label": "Espace texte / image",
      "min": 10,
      "max": 45,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "product_bottom_offset",
      "label": "Décalage image bas",
      "min": -160,
      "max": 30,
      "step": 10,
      "default": -100,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Typographie desktop"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille titre",
      "min": 28,
      "max": 58,
      "step": 1,
      "default": 38,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Interligne titre",
      "min": 90,
      "max": 130,
      "step": 1,
      "default": 108,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse titre",
      "default": "600",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-bold" }
      ]
    },
    {
      "type": "range",
      "id": "heading_width",
      "label": "Largeur titre",
      "min": 360,
      "max": 700,
      "step": 10,
      "default": 600,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Taille sous-titre",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "subheading_weight",
      "label": "Graisse sous-titre",
      "default": "500",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" }
      ]
    },
    {
      "type": "range",
      "id": "subheading_width",
      "label": "Largeur sous-titre",
      "min": 320,
      "max": 620,
      "step": 10,
      "default": 460,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "subheading_top_spacing",
      "label": "Espace titre / sous-titre",
      "min": 8,
      "max": 28,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Labels desktop"
    },
    {
      "type": "range",
      "id": "label_top",
      "label": "Position labels haut",
      "min": 160,
      "max": 430,
      "step": 10,
      "default": 230,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "left_label_position",
      "label": "Position label gauche",
      "min": 10,
      "max": 45,
      "step": 1,
      "default": 18,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "right_label_position",
      "label": "Position label droite",
      "min": 10,
      "max": 45,
      "step": 1,
      "default": 18,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Taille texte labels",
      "min": 14,
      "max": 30,
      "step": 1,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "label_padding_y",
      "label": "Padding vertical labels",
      "min": 6,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "label_padding_x",
      "label": "Padding horizontal labels",
      "min": 10,
      "max": 28,
