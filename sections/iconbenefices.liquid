<section
  class="pureva-blue-benefits-section"
  style="
    --pbb-bg: {{ section.settings.section_background }};
    --pbb-text: {{ section.settings.text_color }};
    --pbb-muted: {{ section.settings.description_color }};
    --pbb-icon: {{ section.settings.icon_color }};
    --pbb-highlight-bg: {{ section.settings.highlight_background }};
    --pbb-highlight-text: {{ section.settings.highlight_text_color }};
    --pbb-button-bg: {{ section.settings.button_background }};
    --pbb-button-text: {{ section.settings.button_text_color }};
    --pbb-max-width: {{ section.settings.max_width }}px;
    --pbb-padding-y: {{ section.settings.desktop_padding_y }}px;
    --pbb-mobile-padding-y: {{ section.settings.mobile_padding_y }}px;
  "
>
  <div class="pureva-blue-benefits-container">

    {% if section.settings.heading != blank %}
      <h2 class="pureva-blue-benefits-heading">
        {{ section.settings.heading_before }}
        {% if section.settings.highlight_word != blank %}
          <span>{{ section.settings.highlight_word }}</span>
        {% endif %}
        {{ section.settings.heading_after }}
      </h2>
    {% endif %}

    <div class="pureva-blue-benefits-grid">
      {% for block in section.blocks %}
        <div class="pureva-blue-benefit-card" {{ block.shopify_attributes }}>
          {% if block.settings.svg_icon != blank %}
            <div class="pureva-blue-benefit-icon">
              {{ block.settings.svg_icon }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="pureva-blue-benefits-button-wrap">
        <a href="{{ section.settings.button_link }}" class="pureva-blue-benefits-button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800;900&display=swap');

  .pureva-blue-benefits-section {
    width: 100%;
    background: var(--pbb-bg);
    color: var(--pbb-text);
    font-family: 'Instrument Sans', Arial, Helvetica, sans-serif;
    padding: var(--pbb-padding-y) {{ section.settings.desktop_padding_x }}px;
    overflow: hidden;
  }

  .pureva-blue-benefits-container {
    width: 100%;
    max-width: var(--pbb-max-width);
    margin: 0 auto;
    text-align: center;
  }

  .pureva-blue-benefits-heading {
    max-width: {{ section.settings.heading_width }}px;
    margin: 0 auto {{ section.settings.heading_bottom_spacing }}px auto;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.12;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: -1.2px;
    color: var(--pbb-text);
  }

  .pureva-blue-benefits-heading span {
    display: inline-block;
    padding: 0 8px 2px 8px;
    background: var(--pbb-highlight-bg);
    color: var(--pbb-highlight-text);
    line-height: 1;
  }

  .pureva-blue-benefits-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
    align-items: start;
  }

  .pureva-blue-benefit-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: var(--pbb-text);
  }

  .pureva-blue-benefit-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin-bottom: {{ section.settings.icon_bottom_spacing }}px;
    color: var(--pbb-icon);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .pureva-blue-benefit-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .pureva-blue-benefit-icon svg path,
  .pureva-blue-benefit-icon svg circle,
  .pureva-blue-benefit-icon svg rect,
  .pureva-blue-benefit-icon svg line,
  .pureva-blue-benefit-icon svg polyline,
  .pureva-blue-benefit-icon svg polygon {
    stroke: currentColor;
  }

  .pureva-blue-benefit-card h3 {
    max-width: {{ section.settings.card_title_width }}px;
    margin: 0 auto {{ section.settings.card_title_spacing }}px auto;
    font-size: {{ section.settings.card_title_size }}px;
    line-height: 1.18;
    font-weight: {{ section.settings.card_title_weight }};
    color: var(--pbb-text);
    letter-spacing: -0.3px;
  }

  .pureva-blue-benefit-card p {
    max-width: {{ section.settings.card_text_width }}px;
    margin: 0 auto;
    font-size: {{ section.settings.card_text_size }}px;
    line-height: 1.45;
    font-weight: {{ section.settings.card_text_weight }};
    color: var(--pbb-muted);
  }

  .pureva-blue-benefits-button-wrap {
    margin-top: {{ section.settings.button_top_spacing }}px;
  }

  .pureva-blue-benefits-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: {{ section.settings.button_min_width }}px;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    border-radius: 999px;
    background: var(--pbb-button-bg);
    color: var(--pbb-button-text);
    font-size: {{ section.settings.button_text_size }}px;
    line-height: 1;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .pureva-blue-benefits-button:hover {
    transform: translateY(-1px);
    opacity: 0.92;
  }

  @media screen and (max-width: 749px) {
    .pureva-blue-benefits-section {
      padding: var(--pbb-mobile-padding-y) {{ section.settings.mobile_padding_x }}px;
    }

    .pureva-blue-benefits-heading {
      max-width: {{ section.settings.mobile_heading_width }}px;
      margin-bottom: {{ section.settings.mobile_heading_bottom_spacing }}px;
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: 1.12;
      letter-spacing: -0.8px;
    }

    .pureva-blue-benefits-grid {
      display: flex;
      gap: {{ section.settings.mobile_card_gap }}px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 0 0 8px 0;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .pureva-blue-benefits-grid::-webkit-scrollbar {
      display: none;
    }

    .pureva-blue-benefit-card {
      flex: 0 0 {{ section.settings.mobile_card_width }}px;
      scroll-snap-align: center;
      padding: {{ section.settings.mobile_card_padding_y }}px {{ section.settings.mobile_card_padding_x }}px;
      border-radius: {{ section.settings.mobile_card_radius }}px;
      background: {{ section.settings.mobile_card_background }};
      border: 1px solid {{ section.settings.mobile_card_border }};
    }

    .pureva-blue-benefit-icon {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
      margin-bottom: {{ section.settings.mobile_icon_bottom_spacing }}px;
    }

    .pureva-blue-benefit-card h3 {
      max-width: 100%;
      font-size: {{ section.settings.mobile_card_title_size }}px;
      margin-bottom: {{ section.settings.mobile_card_title_spacing }}px;
    }

    .pureva-blue-benefit-card p {
      max-width: 100%;
      font-size: {{ section.settings.mobile_card_text_size }}px;
    }

    .pureva-blue-benefits-button-wrap {
      margin-top: {{ section.settings.mobile_button_top_spacing }}px;
    }

    .pureva-blue-benefits-button {
      min-width: {{ section.settings.mobile_button_min_width }}px;
      padding: {{ section.settings.mobile_button_padding_y }}px {{ section.settings.mobile_button_padding_x }}px;
      font-size: {{ section.settings.mobile_button_text_size }}px;
    }
  }
</style>

{% schema %}
