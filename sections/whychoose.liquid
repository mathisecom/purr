<section
  id="pureva-why-{{ section.id }}"
  class="pureva-why-section"
  style="
    --why-bg: {{ section.settings.section_background }};
    --why-text: {{ section.settings.text_color }};
    --why-muted: {{ section.settings.muted_text_color }};
    --why-highlight-bg: {{ section.settings.highlight_background }};
    --why-highlight-text: {{ section.settings.highlight_text_color }};
    --why-divider: {{ section.settings.divider_color }};
    --why-card-bg-mobile: {{ section.settings.mobile_card_background }};
    --why-max-width: {{ section.settings.max_width }}px;
    --why-padding-y: {{ section.settings.desktop_padding_y }}px;
    --why-mobile-padding-y: {{ section.settings.mobile_padding_y }}px;
  "
>
  <div class="pureva-why-container">
    {% if section.settings.heading != blank %}
      <h2 class="pureva-why-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="pureva-why-grid {% if section.settings.mobile_slider %}is-mobile-slider{% endif %}">
      {% for block in section.blocks %}
        <div class="pureva-why-item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="pureva-why-icon">
              {{ block.settings.icon }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3>
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.highlight != blank %}
            <div class="pureva-why-highlight">
              {{ block.settings.highlight }}
            </div>
          {% endif %}

          {% if block.settings.text != blank %}
            <p>
              {{ block.settings.text }}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800;900&display=swap');

  #pureva-why-{{ section.id }} {
    width: 100%;
    background: var(--why-bg);
    color: var(--why-text);
    font-family: 'Instrument Sans', Arial, Helvetica, sans-serif;
    padding: var(--why-padding-y) {{ section.settings.desktop_padding_x }}px;
    overflow: hidden;
  }

  #pureva-why-{{ section.id }} .pureva-why-container {
    width: 100%;
    max-width: var(--why-max-width);
    margin: 0 auto;
    text-align: center;
  }

  #pureva-why-{{ section.id }} .pureva-why-heading {
    margin: 0 0 {{ section.settings.heading_bottom_spacing }}px 0;
    color: var(--why-text);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: -0.6px;
  }

  #pureva-why-{{ section.id }} .pureva-why-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    align-items: start;
  }

  #pureva-why-{{ section.id }} .pureva-why-item {
    position: relative;
    min-height: {{ section.settings.item_min_height }}px;
    padding: 0 {{ section.settings.item_padding_x }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  #pureva-why-{{ section.id }} .pureva-why-item:not(:last-child)::after {
    content: "";
    position: absolute;
    top: {{ section.settings.divider_top }}px;
    right: 0;
    width: 1px;
    height: {{ section.settings.divider_height }}px;
    border-right: 1px {{ section.settings.divider_style }} var(--why-divider);
  }

  #pureva-why-{{ section.id }} .pureva-why-icon {
    height: {{ section.settings.icon_box_height }}px;
    margin-bottom: {{ section.settings.icon_bottom_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.icon_size }}px;
    line-height: 1;
  }

  #pureva-why-{{ section.id }} .pureva-why-icon svg {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: block;
  }

  #pureva-why-{{ section.id }} .pureva-why-item h3 {
    margin: 0 0 {{ section.settings.title_bottom_spacing }}px 0;
    color: var(--why-text);
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.05;
    font-weight: {{ section.settings.title_weight }};
    letter-spacing: -0.7px;
  }

  #pureva-why-{{ section.id }} .pureva-why-highlight {
    display: inline;
    width: fit-content;
    margin: 0 auto {{ section.settings.highlight_bottom_spacing }}px auto;
    padding: {{ section.settings.highlight_padding_y }}px {{ section.settings.highlight_padding_x }}px;
    background: var(--why-highlight-bg);
    color: var(--why-highlight-text);
    font-size: {{ section.settings.highlight_size }}px;
    line-height: 1.15;
    font-weight: {{ section.settings.highlight_weight }};
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  #pureva-why-{{ section.id }} .pureva-why-item p {
    max-width: {{ section.settings.text_width }}px;
    margin: 0 auto;
    color: var(--why-muted);
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.35;
    font-weight: {{ section.settings.text_weight }};
  }

  @media screen and (max-width: 989px) {
    #pureva-why-{{ section.id }} {
      padding: var(--why-mobile-padding-y) {{ section.settings.mobile_padding_x }}px;
    }

    #pureva-why-{{ section.id }} .pureva-why-heading {
      margin-bottom: {{ section.settings.mobile_heading_bottom_spacing }}px;
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: 1.12;
      letter-spacing: -0.5px;
    }

    #pureva-why-{{ section.id }} .pureva-why-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.mobile_grid_gap }}px;
    }

    #pureva-why-{{ section.id }} .pureva-why-grid.is-mobile-slider {
      display: flex;
      gap: {{ section.settings.mobile_slider_gap }}px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 0 0 8px 0;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    #pureva-why-{{ section.id }} .pureva-why-grid.is-mobile-slider::-webkit-scrollbar {
      display: none;
    }

    #pureva-why-{{ section.id }} .pureva-why-grid.is-mobile-slider .pureva-why-item {
      flex: 0 0 {{ section.settings.mobile_card_width }}px;
      scroll-snap-align: center;
    }

    #pureva-why-{{ section.id }} .pureva-why-item {
      min-height: {{ section.settings.mobile_item_min_height }}px;
      padding: {{ section.settings.mobile_item_padding_y }}px {{ section.settings.mobile_item_padding_x }}px;
      border-radius: {{ section.settings.mobile_card_radius }}px;
      background: var(--why-card-bg-mobile);
    }

    #pureva-why-{{ section.id }} .pureva-why-item::after {
      display: none;
    }

    #pureva-why-{{ section.id }} .pureva-why-icon {
      height: {{ section.settings.mobile_icon_box_height }}px;
      margin-bottom: {{ section.settings.mobile_icon_bottom_spacing }}px;
      font-size: {{ section.settings.mobile_icon_size }}px;
    }

    #pureva-why-{{ section.id }} .pureva-why-icon svg {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
    }

    #pureva-why-{{ section.id }} .pureva-why-item h3 {
      margin-bottom: {{ section.settings.mobile_title_bottom_spacing }}px;
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    #pureva-why-{{ section.id }} .pureva-why-highlight {
      margin-bottom: {{ section.settings.mobile_highlight_bottom_spacing }}px;
      font-size: {{ section.settings.mobile_highlight_size }}px;
    }

    #pureva-why-{{ section.id }} .pureva-why-item p {
      max-width: 100%;
      font-size: {{ section.settings.mobile_text_size }}px;
    }
  }
</style>

{% schema %}
