      "label": "Espace titre / cartes",
      "min": 10,
      "max": 80,
      "step": 5,
      "default": 35,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_text_size",
      "label": "Taille texte cartes",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "card_text_weight",
      "label": "Graisse texte cartes",
      "default": "700",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ]
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Taille rond numéro",
      "min": 20,
      "max": 42,
      "step": 1,
      "default": 31,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "number_text_size",
      "label": "Taille numéro",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "number_position_top",
      "label": "Position numéro haut",
      "min": 8,
      "max": 30,
